generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model test {
  id String @id @default(uuid())
}

model panel_users {
  id              String        @id
  first_name      String
  last_name       String
  email           String        @unique
  password        String
  user_type       PanelUserType
  approval_status Boolean       @default(false)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now())
}

enum PanelUserType {
  ADMIN
  MODERATOR
}
